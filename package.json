{
  "name": "cyclemetry",
  "version": "0.3.0",
  "scripts": {
    "prepare": "git config core.hooksPath scripts/git-hooks || true",
    "dev": "node scripts/dev.mjs",
    "build": "CYCLEMETRY_BUILD_STAMP=$(date +%s) app/node_modules/.bin/tauri build",
    "lint": "pnpm --dir app lint",
    "build:wasm": "node scripts/build-wasm.mjs",
    "format": "node scripts/update-templates-readme.mjs && pnpm --dir app format && cargo fmt --manifest-path src-tauri/Cargo.toml",
    "release:check": "node scripts/release-check.mjs",
    "release": "node scripts/release.mjs"
  },
  "packageManager": "pnpm@10.25.0"
}
