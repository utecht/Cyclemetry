{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cyclemetry",
  "identifier": "com.cyclemetry",
  "build": {
    "frontendDist": "../app/dist",
    "devUrl": null,
    "beforeDevCommand": null,
    "beforeBuildCommand": "pnpm -C app vite-build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Cyclemetry",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "devtools": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "minWidth": 980,
        "trafficLightPosition": { "x": 15, "y": 30 }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZBM0NFOThBM0YxMEM3MTYKUldRV3h4QS9pdWs4YWtwMFdRN1B0TXFIRzJpUHErb0lTMkYvZDFleVAveG94dFdRZVBYejJ2b3MK",
      "endpoints": [
        "https://github.com/walkersutton/cyclemetry/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "resources": {
      "../resources/fonts/*": "fonts/",
      "../templates/_assets/*.png": "assets/",
      "../templates/_assets/*.svg": "assets/",
      "../templates/_assets/*.webp": "assets/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
